{
  "name": "api",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "node --watch src/index.ts",
    "build": "tsup src/index.ts --format esm",
    "start": "node dist/index.js",
    "lint": "eslint",
    "format": "prettier --write \"**/*.ts\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^5.2.1"
  },
  "devDependencies": {
    "@blak/eslint-config": "workspace:^",
    "@blak/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/node": "^25.1.0",
    "eslint": "^9.39.2",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
